# For Unicode-related stuff.
# https://www.unicode.org/Public/UCD/latest/ucd/

CommentLine :- "#" NonNewLineUnicodeCharacter* NewLineCharacter

Comment :- CommentLine (WhiteSpaceCharacter* CommentLine)*

NonNewLineUnicodeCharacter :- !NewLineCharacter

NewLineCharacter :- 000A..000D | 0085 | 2028 | 2029

WhiteSpaceCharacter :-
	0009..000D
	| 0020
	| 0085
	| 00A0
	| 1680
	| 2000..200A
	| 2028
	| 2029
	| 202F
	| 205F
	| 3000

Separator :- Comment | WhiteSpaceCharacter

BooleanLiteral :- "true" | "false"

NumberLiteral :-
	BinaryNumberLiteral
	| OctalNumberLiteral
	| DecimalNumberLiteral
	| HexadecimalNumberLiteral

BinaryNumberLiteral :- "0" ("b" | "B") BinaryDigit (","? BinaryDigit)*

BinaryDigit :- "0" | "1"

OctalNumberLiteral :- "0" ("o" | "O") OctalDigit (","? OctalDigit)*

OctalDigit :- BinaryDigit | "2" | "3" | "4" | "5" | "6" | "7"

DecimalNumberLiteral :-
	IntegerNumberLiteral
	| ScientificNumberLiteral
	| FloatingPointNumberLiteral

IntegerNumberLiteral :- DecimalDigit (","? DecimalDigit)*

ScientificNumberLiteral :-
	(IntegerNumberLiteral | FloatingPointNumberLiteral)
	("e" | "E") ("+" | "-")? IntegerNumberLiteral

FloatingPointNumberLiteral :- IntegerNumberLiteral "." IntegerNumberLiteral

DecimalDigit :- OctalDigit | "8" | "9"

HexadecimalNumberLiteral :- "0" ("x" | "X") HexadecimalDigit (","? HexadecimalDigit)*

HexadecimalDigit :- DecimalDigit | "a-f" | "A-F"

StringLiteral :- "'" ("\{" | InterpolatedValue | NonApostropheCharacter)* "'"

InterpolatedValue :- "{" Separator* Expression Separator* "}"

NonApostropheCharacter :- !0027

# https://www.unicode.org/Public/UCD/latest/ucd/DerivedCoreProperties.txt
Identifier :-
	<any character which conforms to XID_Start property>
	<any character which conforms to XID_Continue property>*

# A QUALIFIED name is one or more identifiers joined by `.`.  It appears only
# where `.` has no other meaning -- a TYPE reference and a CONSTRUCTOR pattern --
# to name an item reached through a namespace: a member of a nested `module`
# (`Geo.Shape`, `Geo.Circle`) or of a whole-module import (`math.Option`,
# `math.Some`).  In value/expression position a qualified name is instead formed
# from member-access `.` on the namespace (see Postfix).
QualifiedName :- Identifier ("." Identifier)*

Block :- "{" Separator* (Expression (Separator+ Expression)*)* Separator* "}"

# A type annotation: the optional `: Type` suffix on definitions, function
# parameters and function return positions.  A leading run of separators
# before the colon is allowed (so `a: T` and `a : T` both parse).
TypeAnnotation :- Separator* ":" Separator* TypeExpression

# A tuple mixes positional and labeled members, each optionally `mutable`.
# Labeled members may appear in any order; positional order is significant.
Tuple :- "(" Separator* (TupleMember (Separator+ TupleMember)*)* Separator* ")"

# A member is either a SPREAD (splice another record's fields in) or a
# (possibly mutable) labeled / positional member.  Spreads are emitted first,
# so an explicit field overrides a spread field of the same key.
TupleMember :- Spread | Mutability? (LabeledMember | Expression)

Spread :- ".." Expression

LabeledMember :- Identifier TypeAnnotation? Separator* "=" Separator* Expression

# `mutable` and `opaque` (below) and `type` (below) are SOFT keywords: each
# must be followed by a separator to be recognised, so they remain usable as
# ordinary identifiers otherwise.
Mutability :- "mutable" Separator+

Function :-
	TypeParameters?
	"(" Separator* (Parameter (Separator+ Parameter)*)* Separator* ")"
	TypeAnnotation?
	Separator* Expression

Parameter :- IrrefutablePattern TypeAnnotation?

# Patterns are used by `match` arms, destructuring definitions and function
# parameters.  An IRREFUTABLE pattern (parameters, destructuring) cannot fail,
# so it excludes literal patterns; a full Pattern (match arms) includes them.
Pattern :-
	ConstructorPattern
	| RecordPattern
	| NumberLiteral
	| BooleanLiteral
	| StringLiteral
	| "_"
	| Identifier

# A tagged-union constructor pattern.  Nullary constructors are matched with
# empty parens (`None()`), so a bare identifier is unambiguously a binding.  The
# name may be QUALIFIED (`math.Some(v)`) for a constructor from a whole-module
# import or a nested module.
ConstructorPattern :-
	QualifiedName "(" Separator* (Pattern (Separator+ Pattern)*)? Separator* ")"

RecordPattern :- "(" Separator* (PatternMember (Separator+ PatternMember)*)* Separator* ")"

# A labeled member uses `=` (`(x = p)` matches field x against p), mirroring
# labeled tuple values and avoiding the typed-binder lookalike of `:`.
PatternMember :- Identifier Separator* "=" Separator* Pattern | Pattern

IrrefutablePattern :- IrrefutableRecordPattern | "_" | Identifier

IrrefutableRecordPattern :-
	"(" Separator* (IrrefutablePatternMember (Separator+ IrrefutablePatternMember)*)* Separator* ")"

IrrefutablePatternMember :-
	Identifier Separator* "=" Separator* IrrefutablePattern | IrrefutablePattern

# Member access and calls are postfix operations on a primary.
# An access chain may end in an assignment, used to mutate a `mutable` member.
Postfix :- Primary PostfixOperator* Assignment?

Primary :-
	NumberLiteral
	| BooleanLiteral
	| StringLiteral
	| Tuple
	| Block
	| Identifier

PostfixOperator :-
	"." Accessor
	| "(" Separator* (CallArgument (Separator+ CallArgument)*)* Separator* ")"

# A `_` argument is a placeholder (hole): a call with holes evaluates to a
# function awaiting those arguments, in order.  e.g. `foo(_ 'x')` has the
# type of `foo` with its first parameter still outstanding.
CallArgument :- "_" | Expression

Accessor :- Identifier | DecimalDigit+

# Only valid when the target is a member access; "=" must not begin "==".
Assignment :- Separator* "=" Separator* Expression

Unary :- UnaryOperator Separator* Expression

UnaryOperator :- "-" | "!" | "~"

Binary :-
	BaseExpression
	(Separator* BinaryOperator Separator* BaseExpression)+

# The number after each operator is its precedence (higher binds tighter).
# `&& ^^ ||` are BITWISE operators on numbers; `& ^ |` are BOOLEAN logical
# operators on booleans.  The doubled (bitwise) forms must be tried before the
# single (boolean) ones during lexing, and bind tighter than comparison.
BinaryOperator :-
	"*"    # 12
	| "/"  # 12
	| "+"  # 11
	| "-"  # 11
	| "<<" # 10
	| ">>" # 10
	| "&&" # 9   # bitwise and (numbers)
	| "^^" # 8   # bitwise xor (numbers)
	| "||" # 7   # bitwise or  (numbers)
	| "<=" # 6
	| "<"  # 6
	| ">=" # 6
	| ">"  # 6
	| "==" # 5
	| "!=" # 5
	| "&"  # 4   # boolean and
	| "^"  # 3   # boolean xor
	| "|"  # 2   # boolean or
	| "->" # 1

Conditional :-
	"if" Separator* Expression
	Separator* Expression
	Separator* "else" Separator* Expression

Definition :- Identifier TypeAnnotation? Separator* "=" Separator* Expression

# A destructuring definition binds a record pattern's variables.  The LHS is
# a record pattern (a bare `name = value` is an ordinary Definition).
Destructuring :- IrrefutableRecordPattern Separator* "=" Separator* Expression

# `match` is a soft keyword.  The scrutinee is parsed at the Postfix (atom)
# level so it never swallows the arm-separating `|`; wrap a compound scrutinee
# as `match { a + b } | ...` or `match (t) | ...`.  Each arm is one or more
# `|`-separated alternative patterns (an OR-PATTERN; all alternatives must
# bind the same variables), an optional guard, and a result.  In this
# (union-free) form every pattern is consistent with the scrutinee's type.
Match :-
	"match" Separator+ Postfix
	(Separator* "|" Separator* MatchArm)+

MatchArm :-
	Pattern (Separator* "|" Separator* Pattern)*
	Separator* ("if" Separator+ Expression Separator*)? "=>" Separator* Expression

# A `type` declaration introduces a named type, which is one of:
#  * a TAGGED UNION (variant / sum type): a `|`-separated list of constructors;
#  * a STRUCTURAL alias for a type expression (default); or
#  * a NOMINAL type when the body is prefixed with `opaque`.
TypeDeclaration :-
	"type" Separator+ Identifier TypeParameters? Separator*
	"=" Separator* DeclarationBody

DeclarationBody :- VariantBody | Opaque? TypeExpression

# A body is a variant when it has a leading `|`, two or more constructors, or
# a single constructor written with a field list `Name(...)` (this last rule
# distinguishes `type Wrap = Wrap(number)` from the alias `type Id = number`).
# Constructors are values/functions; construct with ordinary application,
# e.g. `Circle(5)`, and a nullary constructor like `None` is just a value.
VariantBody :- "|"? Constructor (Separator* "|" Separator* Constructor)*

Constructor :-
	Identifier ("(" Separator* TypeExpression (Separator+ TypeExpression)* Separator* ")")?

Opaque :- "opaque" Separator+

# A type-parameter list, used by declarations AND function generics.  A
# parameter is proper (kind `*`, optionally bounded with `: TypeExpression`)
# or HIGHER-KINDED, written `Name<_ ... _>` where the number of `_` holes is
# its arity (so `F<_>` has kind `* -> *`).  A higher-kinded parameter `F` is
# then applied like any constructor, `F<A>`.
#     <A b>                       two proper parameters
#     <T: (number ..)>            T (proper) bounded by an open record
#     <F<_> A>                    F is a one-argument constructor, A is proper
TypeParameters :- "<" Separator* TypeParameter (Separator+ TypeParameter)* Separator* ">"

TypeParameter :-
	Identifier (
		"<" Separator* "_" (Separator+ "_")* Separator* ">"   # higher-kinded
		| (Separator* ":" Separator* TypeExpression)?          # proper, optional bound
	)

# A type expression is a quantified (polymorphic) type, a parenthesized form
# (a tuple type, or a function type when a `: ReturnType` follows), or a named
# reference.
TypeExpression :- QuantifiedType | ParenthesizedType | TypeReference

# A QUANTIFIED type bakes a `forall` into the type, so a polymorphic type can
# be written in an annotation -- a function parameter or field that is ITSELF
# polymorphic.  This is how RANK-N types are expressed; e.g. a function whose
# argument must be polymorphic:
#     applyToBoth = (f: <A>(A): A): (number string) (f(1) f('hi'))
# It differs from a generic type ALIAS (`type Id<A> = (A): A`), whose
# parameters sit on the type NAME and which must be applied (`Id<number>`).
# Quantifiers are PREDICATIVE: a polytype may not be a type argument, so
# `List<<A>(A): A>` is rejected.  Inference is bidirectional -- a value is
# CHECKED against a polytype annotation; annotations are required only where a
# `forall` would otherwise have to be guessed.
QuantifiedType :- TypeParameters Separator* TypeExpression

# Members optionally end with `..` (optionally naming the rest, `..R`),
# making the record OPEN ("and possibly more fields"); otherwise it is
# closed/exact.  Naming the rest with `..R` (R a type parameter) lets two
# annotations share a tail, so a function can preserve a caller's extra
# fields (open-row results).  A trailing `: ReturnType` instead makes it a
# FUNCTION type, whose parameters are the member types:
#     (number string)            closed tuple type
#     (one: number two: string)  tuple type with labeled members
#     (x: string ..)             OPEN record: at least field x, plus more
#     (x: string ..R)            OPEN record capturing the rest as R
#     (..)                       any record
#     (number): number           function type  (number) -> number
#     (number string): boolean   function type  (number, string) -> boolean
ParenthesizedType :-
	"(" Separator* (TypeMember (Separator+ TypeMember)*)? (Separator+ ".." Identifier?)? Separator* ")"
	(Separator* ":" Separator* TypeExpression)?

TypeMember :- Mutability? (Identifier Separator* ":" Separator* TypeExpression | TypeExpression)

# A named type, optionally applied to angle-bracketed type arguments.  The name
# may be QUALIFIED (`math.Option`) for a type from a whole-module import or a
# nested module:
#     number      Pair<A b>      Box<number>      math.Option<number>
TypeReference :- QualifiedName TypeArguments?

# A type argument may be a HOLE `_` (a placeholder).  A reference with holes,
# or with FEWER arguments than the type's arity, is a SECTION -- a partial type
# application that yields a type-level function (kind `* -> ..`) awaiting the
# remaining arguments.  Both forms have kind equal to the number of missing
# positions, so a section can be bound to a higher-kinded alias or passed as a
# higher-kinded argument; applying it to the remaining arguments reduces it:
#     type StringOr = Either<_ string>     # * -> *  ; StringOr<number> = Either<number string>
#     type NumberOr = Either<number>       # * -> *  ; NumberOr<boolean> = Either<number boolean>
#     Twice<Either<_ string> number>       # the section is the F<_> argument
# Holes may only abstract PROPER (kind-`*`) positions.
TypeArguments :- "<" Separator* TypeArgument (Separator+ TypeArgument)* Separator* ">"

TypeArgument :- "_" | TypeExpression

BaseExpression :-
	TypeDeclaration
	| Definition
	| Destructuring
	| Function
	# Conditional and Match precede Binary so their bodies / arm results bind
	# greedily (`match s | _ => a + b` keeps `a + b` in the arm).
	| Conditional
	| Match
	| Binary
	| Unary
	| Postfix

Expression :-
	Binary
	| BaseExpression

# A program is a sequence of items: imports, exports, nested modules, and
# ordinary expressions (definitions, type declarations, bare expressions).
Program :-
	Separator*
	(ProgramItem Separator*)*

ProgramItem :- Use | Public | External | Module | Expression

# An IMPORT, in two forms:
#  * `use ./math:(add Option Some)` brings the LISTED names into scope; or
#  * `use ./math` (no `:` clause) brings the WHOLE module in under a NAMESPACE
#    derived from the path's base name (`math`), so its public items are reached
#    as `math.add`, `math.Option`, `math.Some`, ... (no name list needed).
# The path is relative (no `.sl` extension); names resolve uniformly across
# values, types and constructors against the source module's exported interface.
# `use` is a soft keyword (mandatory separator).
Use :- "use" Separator+ ImportPath (Separator* ":" Separator* ImportNames)?

ImportPath :- PathCharacter+               # any chars except ":", whitespace, "(", ")"

# The names are always parenthesised (no one-name shorthand).
ImportNames :- "(" Separator* Identifier (Separator+ Identifier)* Separator* ")"

# An EXPORT.  `public` prefixes a definition, `type` declaration, `external`, or
# nested `module` to expose it to importers; everything else is module-private.
# Exporting a tagged-union type exports its constructors too; exporting an
# `external` lets a foreign binding be declared once and imported elsewhere; a
# top-level `public module` exports its public members (reached by importers via
# a whole-module `use`).  `public` is a soft keyword.
Public :- "public" Separator+ (External | Module | Expression)

# A NESTED MODULE groups items under a name as a COMPILE-TIME namespace -- it is
# not a value and has no type.  Its body is itself a sequence of program items,
# so modules nest and may hold definitions, `type` declarations, `external`s,
# `use`s and further modules, each optionally `public`.  Members are reached as
# `Name.member`; `public` exposes a member outside the module (within the file),
# and a top-level `public module` additionally exports across files.  Member
# names are QUALIFIED with the module path, so two modules may reuse a name (and
# a constructor's runtime tag is likewise qualified).  `module` is a soft
# keyword (mandatory separator).
Module :-
	"module" Separator+ Identifier Separator* "=" Separator*
	"(" Separator* (ProgramItem Separator*)* ")"

# A FOREIGN (JavaScript) IMPORT.  `external` binds a name to a piece of JS with
# a trusted type ascription -- the one unsafe point of the boundary.  The
# source is one of: omitted -- an ambient global of the same name
# (`external max : T`); a JS expression (`= 'Math.max'`); or a renamed module
# import (`= 'print' from './io.js'`).  A function type gets a currying shim in
# the back end; all values (tuples and variants included) cross unchanged.
# `external` is a soft keyword.  JsString is single-quoted but, unlike the
# language's own strings, raw -- no escapes or interpolation.
External :-
	"external" Separator+ Identifier Separator* ":" Separator* TypeExpression
	(Separator* ExternalSource)?

ExternalSource :-
	"=" Separator* JsString Separator* "from" Separator* JsString   # renamed module import
	| "=" Separator* JsString                                       # JS expression
	| "from" Separator* JsString                                    # module import, same name

JsString :- "'" (!"'")* "'"

# Import cycles are rejected; mutual recursion is a within-file feature.
